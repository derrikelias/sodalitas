<header class="site {% if minimalHeader %}site-minimal{% endif %}" id="site-header">
  <div class="brand {% if minimalHeader %}brand-center{% endif %}" id="site-brand">
    <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.1" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="17"/>
      <path d="M20 3v3M20 34v3M3 20h3M34 20h3" stroke-linecap="round"/>
      <path d="M24 15c0-2.5-2-4-4.3-4s-4.2 1.4-4.2 3.1c0 2.3 2.8 2.9 5 3.6c2.8 0.9 5.5 1.7 5.5 4.5c0 2.3-2.3 3.8-4.9 3.8s-4.6-1.4-4.8-3.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <a href="{{ '/' | url }}" id="site-brand-link" class="mark" style="color: inherit; text-decoration: none;">{{ site.title }}</a>
  </div>
  <div class="header-right">
    <nav class="site" id="site-nav" {% if minimalHeader %}hidden{% endif %}>
      {% for item in site.nav %}
        <a href="{{ item.url | url }}">{{ item.label }}</a>
      {% endfor %}
    </nav>
    <button class="theme-toggle {% if minimalHeader %}theme-toggle-standalone{% endif %}" id="theme-toggle" type="button" aria-label="Toggle dark and light mode">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="4.5"/>
        <path d="M12 2.5v2.5M12 19v2.5M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2.5 12H5M19 12h2.5M4.2 19.8L6 18M18 6l1.8-1.8" stroke-linecap="round"/>
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</header>
