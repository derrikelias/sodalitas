  <div class="header-right">
    <nav class="site" id="site-nav" {% if minimalHeader %}hidden{% endif %}>
      {% for item in site.nav %}
        <a href="{{ item.url | url }}">{{ item.label }}</a>
      {% endfor %}
    </nav>
    <button class="theme-toggle {% if minimalHeader %}theme-toggle-standalone{% endif %}" id="theme-toggle" type="button" aria-label="Toggle dark and light mode">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="4.5"/>
        <path d="M12 2.5v2.5M12 19v2.5M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2.5 12H5M19 12h2.5M4.2 19.8L6 18M18 6l1.8-1.8" stroke-linecap="round"/>
