---
layout: layouts/base.njk
minimalHeader: true
---

<div class="member-header">
  <div class="member-number">No. {{ number }}</div>
  <h1 class="member-name" id="member-name" data-real-name="{{ name }}">Sealed</h1>
  <div class="member-meta" id="member-meta" data-since="{{ memberSince }}" data-role="{{ role }}">
    <span>Awaiting its key</span>
  </div>
</div>

<div
  class="unlock"
  id="unlock"
  data-gallery-base="{{ ('/assets/gallery-encrypted/' + number + '/') | url }}"
  data-salt="{{ salt }}"
  data-iv="{{ iv }}"
  data-ciphertext="{{ ciphertext }}"
  data-iterations="{{ pbkdf2Iterations }}"
>
  <p class="unlock-copy">Only its key opens this page.</p>
  <form id="unlock-form" class="unlock-form">
    <input
      type="password"
      id="unlock-code"
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      placeholder="Enter key"
      aria-label="Access key"
    >
    <button type="submit">Unlock</button>
  </form>
  <p id="unlock-error" class="unlock-error" hidden>That did not work. Please try again.</p>
</div>

<div id="member-content" hidden>
  <section id="timeline-section" hidden>
    <p class="eyebrow">Timeline</p>
    <h2 class="section-title">A record, in order</h2>
    <ul class="timeline" id="timeline-list"></ul>
  </section>

  <section id="memories-section" hidden>
    <p class="eyebrow">Shared Memories</p>
    <h2 class="section-title" id="memories-title"></h2>
    <p id="memories-body" style="line-height: var(--leading-relaxed); color: var(--colour-ink-soft); max-width: var(--content-width-narrow);"></p>
  </section>

  <section id="countries-section" hidden>
    <p class="eyebrow">Countries Visited Together</p>
    <h2 class="section-title" id="countries-count"></h2>
    <ul class="countries" id="countries-list"></ul>
  </section>

  <section id="gallery-section" hidden>
    <p class="eyebrow">Gallery</p>
    <h2 class="section-title">Fragments</h2>
    <div class="gallery-grid" id="gallery-grid"></div>
  </section>

  <section id="message-section" hidden>
    <p class="eyebrow" style="text-align:center;">Personal Message</p>
    <p class="message" id="message-text"></p>
  </section>
</div>

<script src="{{ '/assets/js/decrypt.js' | url }}"></script>
